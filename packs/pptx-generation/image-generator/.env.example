# image-generator skill — required environment variables
# Copy these to the project root .env file and fill in actual values.
# Do NOT commit real credentials.

# ========== Backend 1: Azure OpenAI gpt-image-1.5 ==========
AZURE_OPENAI_IMAGE_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_IMAGE_DEPLOYMENT=gpt-image-1.5
AZURE_OPENAI_IMAGE_API_VERSION=2025-04-01-preview
AZURE_OPENAI_IMAGE_TIMEOUT=120
# Optional: API key auth (if unset, uses azure-identity or az cli)
# AZURE_OPENAI_IMAGE_API_KEY=

# ========== Backend 2: Azure FLUX.1-Kontext-pro ==========
AZURE_FLUX_IMAGE_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_FLUX_IMAGE_DEPLOYMENT=FLUX.1-Kontext-pro
AZURE_FLUX_IMAGE_API_VERSION=2025-04-01-preview
AZURE_FLUX_IMAGE_TIMEOUT=180
# Optional: API key auth
# AZURE_FLUX_IMAGE_API_KEY=
