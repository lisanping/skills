# pptx-generation pack — environment variables
# Copy this file to the **project root** as `.env` and fill in actual values.
# Do NOT commit real credentials. The .gitignore in this pack excludes `.env`
# but allows `.env.example` so it stays under version control.
#
# Currently only `image-generator` reads these variables. Other SKILLs in the
# pack do not require any environment configuration.

# ========== image-generator: Backend 1 — Azure OpenAI gpt-image-1.5 =========
AZURE_OPENAI_IMAGE_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_IMAGE_DEPLOYMENT=gpt-image-1.5
AZURE_OPENAI_IMAGE_API_VERSION=2025-04-01-preview
AZURE_OPENAI_IMAGE_TIMEOUT=120
# Optional: API key auth (if unset, uses azure-identity or az cli)
# AZURE_OPENAI_IMAGE_API_KEY=

# ========== image-generator: Backend 2 — Azure FLUX.1-Kontext-pro ===========
AZURE_FLUX_IMAGE_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_FLUX_IMAGE_DEPLOYMENT=FLUX.1-Kontext-pro
AZURE_FLUX_IMAGE_API_VERSION=2025-04-01-preview
AZURE_FLUX_IMAGE_TIMEOUT=180
# Optional: API key auth
# AZURE_FLUX_IMAGE_API_KEY=

# ========== image-generator: Backend enable / disable =======================
# Default backend is gpt-image; FLUX is disabled by default.
IMAGE_BACKEND_GPT_IMAGE_ENABLED=true
IMAGE_BACKEND_FLUX_ENABLED=false
