{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Remediation Proposals",
    "description": "Per-slide or per-cohort remediation output: 1-3 proposals per trigger.",
    "type": "object",
    "required": [
        "remediations"
    ],
    "properties": {
        "remediations": {
            "type": "array",
            "items": {
                "type": "object",
                "required": [
                    "trigger",
                    "proposals"
                ],
                "properties": {
                    "slideId": {
                        "type": "string"
                    },
                    "cohortId": {
                        "type": "string"
                    },
                    "trigger": {
                        "type": "string"
                    },
                    "proposals": {
                        "type": "array",
                        "minItems": 1,
                        "maxItems": 3,
                        "items": {
                            "type": "object",
                            "required": [
                                "form",
                                "rationale"
                            ],
                            "properties": {
                                "form": {
                                    "type": "string",
                                    "enum": [
                                        "parameter_change",
                                        "directional"
                                    ]
                                },
                                "zoneId": {
                                    "type": "string"
                                },
                                "role": {
                                    "type": "string"
                                },
                                "parameter": {
                                    "type": "string"
                                },
                                "oldValue": {
                                    "type": "string"
                                },
                                "newValue": {
                                    "type": "string"
                                },
                                "targetValue": {
                                    "type": "string"
                                },
                                "affectedMembers": {
                                    "type": "array",
                                    "items": {
                                        "type": "string"
                                    }
                                },
                                "guidance": {
                                    "type": "string"
                                },
                                "rationale": {
                                    "type": "string"
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}