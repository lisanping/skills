# Repo-root .gitignore.
#
# Scope: only patterns that apply to **any** pack — Python bytecode, virtual
# envs, generic editor / OS noise, coverage, logs, and a `packs/*/output|build|dist`
# catch-all. Domain-specific binaries (CAD/BIM, PPTX/PDF, images, …) belong in
# the per-pack `.gitignore` so each pack remains self-contained when shared
# standalone.

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
*.egg

# Virtual environments
.venv/
env/
venv/

# IDE
.vscode/settings.json
.idea/

# OS
.DS_Store
Thumbs.db

# Jupyter
.ipynb_checkpoints/

# Coverage / test caches
htmlcov/
.coverage
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Conda
.conda/

# Logs
*.log
logs/

# Local agent / editor caches
.claude/cache/
.copilot/
.cursor/
.vscode/

# Per-pack catch-all (each pack may add more in its own .gitignore)
packs/*/output/
packs/*/build/
packs/*/dist/

# Test artifacts (results dirs are tracked; raw scratch is not)
packs/*/tests/.scratch/

